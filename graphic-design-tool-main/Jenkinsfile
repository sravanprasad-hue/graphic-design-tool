pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Environment') {
            steps {
                dir('graphic-design-tool-main') {
                    sh '''
                        docker --version
                        docker compose version
                        pwd
                        ls -la
                        test -d Backend
                        test -d Frontend
                        test -f docker-compose.yml
                    '''
                }
            }
        }

        stage('Prepare Environment') {
            steps {
                dir('graphic-design-tool-main') {
                    withCredentials([
                        file(
                            credentialsId: 'graphic-backend-env',
                            variable: 'BACKEND_ENV'
                        )
                    ]) {
                        sh '''
                            cp "$BACKEND_ENV" Backend/.env
                            chmod 600 Backend/.env
                            echo "Backend environment prepared"
                        '''
                    }
                }
            }
        }

        stage('Terraform Plan') {
    steps {
        dir('graphic-design-tool-main/terraform') {
            sh '''
                terraform init -input=false
                terraform fmt -check
                terraform validate
                terraform plan -input=false -out=tfplan
            '''
        }
    }
}

stage('Terraform Apply') {
    steps {
        dir('graphic-design-tool-main/terraform') {
            sh '''
                terraform apply -input=false -auto-approve tfplan
            '''
        }
    }
}
        stage('Docker Build') {
            steps {
                dir('graphic-design-tool-main') {
                    sh '''
                        docker compose build
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('graphic-design-tool-main') {
                    sh '''
                        docker compose up -d --force-recreate
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                dir('graphic-design-tool-main') {
                    sh '''
                        sleep 15
                        docker compose ps

                        curl --fail \
                             --retry 5 \
                             --retry-delay 3 \
                             http://localhost/
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'CI/CD Deployment Successful'
        }

        failure {
            echo 'CI/CD Deployment Failed'

            dir('graphic-design-tool-main') {
                sh 'docker compose ps || true'
                sh 'docker compose logs --tail=100 || true'
            }
        }

        always {
            dir('graphic-design-tool-main') {
                sh 'rm -f Backend/.env || true'
            }
        }
    }
}
